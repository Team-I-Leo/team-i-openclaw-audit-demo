# Team-I runtime configuration. Copy this file to .env and edit paths as needed.

AER_MODEL_BACKEND=fallback
AER_DB_PATH=runtime/aer_loop.sqlite
AER_DEMO_ORDER_COUNT=3000
AER_MAX_STEPS=8
AER_MAX_NEW_TOKENS=384

# Local Transformers backend.
AER_MODEL_PATH_7B=models/Qwen2.5-Coder-7B-Instruct
AER_MODEL_PATH_14B=models/Qwen2.5-Coder-14B-Instruct
AER_MODEL_PATH=models/Qwen2.5-Coder-7B-Instruct

# OpenAI-compatible local model server.
AER_MODEL_PORT=18088
AER_OPENAI_BASE_URL=http://127.0.0.1:18088/v1
AER_OPENAI_API_KEY=EMPTY
AER_OPENAI_MODEL=qwen2.5-coder-7b-instruct
AER_ASSERTION_MODEL=qwen2.5-coder-7b-instruct
AER_ROUTER_MODEL=qwen2.5-coder-7b-instruct
AER_INVESTIGATION_MODEL=qwen2.5-coder-7b-instruct
AER_COUNTER_MODEL=qwen2.5-coder-7b-instruct
AER_PASSPORT_MODEL=qwen2.5-coder-14b-instruct
AER_PATTERN_MODEL=qwen2.5-coder-14b-instruct

# Optional conda environment name. Leave empty when using venv.
AER_CONDA_ENV=
